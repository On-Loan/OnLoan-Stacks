(define-read-only (is-liquidatable (user principal) (collateral-type (string-ascii 12)))
  (let (
    (health-factor (try! (contract-call? .collateral-manager-v2 get-health-factor user collateral-type)))
  )
    (ok (< health-factor u10000))
  )
)

(define-read-only (get-max-liquidatable (user principal) (collateral-type (string-ascii 12)))
  (let (
    (position (unwrap! (contract-call? .collateral-manager-v2 get-position user collateral-type) (err u1012)))
    (health-factor (try! (contract-call? .collateral-manager-v2 get-health-factor user collateral-type)))
  )
    (if (>= health-factor u10000)
      (ok u0)
      (if (>= health-factor u8000)
        (ok (/ (* (get borrowed-amount position) u5000) u10000))
        (ok (get borrowed-amount position))
      )
    )
  )
)

(define-read-only (get-liquidation-quote (borrower principal) (collateral-type (string-ascii 12)) (repay-amount uint))
  (let (
    (position (unwrap! (contract-call? .collateral-manager-v2 get-position borrower collateral-type) (err u1012)))
    (price-data (try! (contract-call? .pyth-oracle-adapter-v2 get-price collateral-type)))
    (price (get price price-data))
    (config (unwrap! (contract-call? .onloan-core-v2 get-asset-config collateral-type) (err u1002)))
    (bonus (get liquidation-bonus config))
    (collateral-to-seize (/ (* repay-amount (+ u10000 bonus) u100000000) (* price u10000)))
    (liquidator-bonus (/ (* repay-amount bonus) u10000))
  )
    (ok {
      seized-collateral: collateral-to-seize,
      liquidator-bonus: liquidator-bonus,
      repaid-debt: repay-amount
    })
  )
)
