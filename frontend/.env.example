# OnLoan Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Network: "testnet" or "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# Deployer address (owner of OnLoan contracts)
NEXT_PUBLIC_CONTRACT_DEPLOYER=ST1XHPEWSZYNN2QA9QG9JG9GHRVF6GZSFRWTFB5VV

# Stacks API endpoint
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# sBTC token contract address
NEXT_PUBLIC_SBTC_CONTRACT=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token

# USDCx token contract address (optional — defaults to deployer's usdcx)
# NEXT_PUBLIC_USDCX_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.usdcx

# Pyth Network Hermes API endpoint (for oracle price feeds)
NEXT_PUBLIC_PYTH_ENDPOINT=https://hermes.pyth.network
